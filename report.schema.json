{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/AgentSafe-AI/tooltrust-directory/blob/main/report.schema.json",
  "title": "ToolTrust Security Report",
  "description": "Standard schema for AgentSentry security reports stored in the ToolTrust Directory.",
  "type": "object",
  "required": [
    "tool_id",
    "version",
    "grade",
    "risk_score",
    "scan_date",
    "scanner",
    "source_url",
    "findings",
    "summary",
    "methodology"
  ],
  "additionalProperties": false,
  "properties": {
    "tool_id": {
      "type": "string",
      "description": "Unique, kebab-case identifier for the tool. Must match the report filename (without .json).",
      "pattern": "^[a-z0-9]+(-[a-z0-9]+)*$",
      "examples": ["mcp-server-filesystem", "mcp-server-github"]
    },
    "version": {
      "type": "string",
      "description": "Semver string of the tool version that was scanned.",
      "pattern": "^\\d+\\.\\d+\\.\\d+(-[a-zA-Z0-9.]+)?$",
      "examples": ["1.2.0", "0.6.2"]
    },
    "grade": {
      "type": "string",
      "description": "Letter grade derived from risk_score (A=0-9, B=10-24, C=25-49, D=50-74, F=75+).",
      "enum": ["A", "B", "C", "D", "F"]
    },
    "risk_score": {
      "type": "integer",
      "description": "Composite risk score calculated as sum(SeverityWeight_i * FindingCount_i).",
      "minimum": 0
    },
    "scan_date": {
      "type": "string",
      "description": "ISO 8601 UTC timestamp of when the scan was performed.",
      "format": "date-time",
      "examples": ["2026-03-01T20:00:00Z"]
    },
    "scanner": {
      "type": "string",
      "description": "Scanner name and version that produced this report.",
      "pattern": "^AgentSentry/\\d+\\.\\d+\\.\\d+$",
      "examples": ["AgentSentry/1.0.0"]
    },
    "source_url": {
      "type": "string",
      "description": "Canonical URL of the tool's source repository or registry page.",
      "format": "uri"
    },
    "findings": {
      "type": "array",
      "description": "List of security findings discovered during the scan.",
      "items": {
        "$ref": "#/$defs/Finding"
      }
    },
    "summary": {
      "$ref": "#/$defs/Summary"
    },
    "methodology": {
      "type": "string",
      "description": "URL pointing to the methodology document used for this scan.",
      "format": "uri"
    }
  },
  "$defs": {
    "Finding": {
      "type": "object",
      "required": ["id", "severity", "title", "description", "recommendation"],
      "additionalProperties": false,
      "properties": {
        "id": {
          "type": "string",
          "description": "AgentSentry finding identifier.",
          "pattern": "^AS-\\d{3}$",
          "examples": ["AS-002", "AS-010"]
        },
        "severity": {
          "type": "string",
          "description": "Severity level of the finding.",
          "enum": ["Critical", "High", "Medium", "Low", "Info"]
        },
        "title": {
          "type": "string",
          "description": "Short, human-readable title for the finding.",
          "minLength": 5,
          "maxLength": 100
        },
        "description": {
          "type": "string",
          "description": "Detailed explanation of the vulnerability or weakness.",
          "minLength": 20
        },
        "recommendation": {
          "type": "string",
          "description": "Actionable guidance for the tool maintainer to remediate the finding.",
          "minLength": 20
        }
      }
    },
    "Summary": {
      "type": "object",
      "description": "Aggregated finding counts by severity.",
      "required": ["critical", "high", "medium", "low", "info"],
      "additionalProperties": false,
      "properties": {
        "critical": { "type": "integer", "minimum": 0 },
        "high":     { "type": "integer", "minimum": 0 },
        "medium":   { "type": "integer", "minimum": 0 },
        "low":      { "type": "integer", "minimum": 0 },
        "info":     { "type": "integer", "minimum": 0 }
      }
    }
  }
}
