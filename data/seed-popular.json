{
  "_comment": "Popular MCP servers from mcpmarket.com / smithery.ai. Ensures we don't miss top servers that lack mcp-server in GitHub name/topic.",
  "repos": [
    "erophames/superpowers-mcp",
    "eyaltoledano/claude-task-master",
    "microsoft/playwright-mcp",
    "mindsdb/minds-mcp",
    "LaurieWired/GhidraMCP",
    "clay-inc/clay-mcp",
    "exa-labs/exa-mcp-server",
    "g0t4/mcp-server-commands"
  ],
  "overrides": [
    {
      "_comment": "Individual servers inside the modelcontextprotocol/servers monorepo. The root repo name ('servers') does not match any tool_id, so auto-discovery never re-queues these.",
      "repo": "modelcontextprotocol/servers",
      "tool_id": "mcp-server-filesystem",
      "npm_package": "@modelcontextprotocol/server-filesystem",
      "source_url": "https://github.com/modelcontextprotocol/servers/tree/main/src/filesystem"
    },
    {
      "repo": "modelcontextprotocol/servers",
      "tool_id": "mcp-server-brave-search",
      "npm_package": "@modelcontextprotocol/server-brave-search",
      "source_url": "https://github.com/modelcontextprotocol/servers/tree/main/src/brave-search"
    },
    {
      "repo": "modelcontextprotocol/servers",
      "tool_id": "mcp-server-github",
      "npm_package": "@modelcontextprotocol/server-github",
      "source_url": "https://github.com/modelcontextprotocol/servers/tree/main/src/github"
    }
  ]
}
